# Database
DATABASE_URL=postgresql+asyncpg://sphinx:sphinx_secret@localhost:5432/sphinx

# Redis
REDIS_URL=redis://localhost:6379/0

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Provider credential encryption key (Fernet key - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# Default LLM provider endpoint
DEFAULT_PROVIDER_URL=http://localhost:9000
